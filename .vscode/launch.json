    "version": "0.2.0",
    "configurations": [
        {
            "args": ["-i", "{2 + 3 * 5}"],
            "name": "Python Debugger: martin",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },

        {
            
            "args": ["-i", "Preprocessor/output.gsl"],
            "name": "Python Debugger: gslParser",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
}