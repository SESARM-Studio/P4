digraph G with int weight @NEWLINE
@INDENT node s, y, z, t, x @NEWLINE
edge s --> t, y weight 6, 7 @NEWLINE
edge y --> z weight 9 @NEWLINE
edge y --> x weight -3 @NEWLINE
edge z --> s, x weight 2, 7 @NEWLINE
edge t --> y, z weight 8, -4 @NEWLINE
edge t --> x weight 5 @NEWLINE
edge x --> t weight -2 @NEWLINE
@DEDENT algo bellmanFord(digraph G, node s) @NEWLINE
@INDENT initializeSingleSource(G, s) @NEWLINE
repeat ||G.nodes|| - 1 times @NEWLINE
@INDENT for each edge x1 --> x2 with weight w in G @NEWLINE
@INDENT relax(x1, x2, w) @NEWLINE
@DEDENT @DEDENT for each edge x1 --> x2 with weight w in G @NEWLINE
@INDENT if x2.SPE > x1.SPE + w then @NEWLINE
@INDENT return false @NEWLINE
@DEDENT @DEDENT return true @NEWLINE
@DEDENT algo initializeSingleSource(digraph G, node s) @NEWLINE
@INDENT G.nodes.addAttribute("natural", SPE)  @NEWLINE
G.nodes.addAttribute("node", pi) @NEWLINE
for each v in G.nodes @NEWLINE
@INDENT v.SPE := INF @NEWLINE
v.pi := NIL @NEWLINE
@DEDENT s.SPE := 0 @NEWLINE
@DEDENT algo relax(node x1, node x2, w in int) @NEWLINE
@INDENT if x2.SPE > x1.SPE + w then @NEWLINE
@INDENT x2.SPE := x1.SPE + w @NEWLINE
x2.pi := x1 @NEWLINE
@DEDENT @DEDENT bellmanFord(G, G.nodes.s) @NEWLINE
text mart := "hej" @NEWLINE
$