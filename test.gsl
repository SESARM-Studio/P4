/* This is a multi-line comment.
It ends on this line 
*/
 algo GCDGraphIter(natural a, natural b)
    tree GCDTree // This is a comment
        node r, nodeLeft, nodeRight, refA, refB
        nodes.addAttribute(natural, value)
            /* This is an important message */ nodes = works

        // This is another comment
        nodeLeft.value := a // Comment
        nodeRight.value := b /* Test comment */

        root := r
        edge r --> nodeLeft
        edge r --> nodeRight

        refA := nodeLeft
        refB := nodeRight 

        while refB.value != 0 then
            node tempLeaf
            tempLeaf.value := refA.value % refB.value
            edge refA --> tempLeaf
            refA := refB
            refB := tempLeaf
        r.value := refA.value
            return GCDTree.root.value
